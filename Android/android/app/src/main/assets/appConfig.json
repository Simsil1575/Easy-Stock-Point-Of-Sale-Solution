    "regexInternalExternal": {
      "rules": [
        {
          "regex": "^(?!https?://).*",
          "mode": "external",
          "label": "Non-web links",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://192\\.168\\..*",
          "mode": "internal",
          "label": "Local Network",
          "pagesToTrigger": "all"
        },
        {
          "regex": "https?://10\\..*",
          "mode": "internal",
          "label": "Local Network 10.x",
          "pagesToTrigger": "all"
        },
        {
          "regex": "https?://172\\.(1[6-9]|2[0-9]|3[0-1])\\..*",
          "mode": "internal",
          "label": "Local Network 172.x",
          "pagesToTrigger": "all"
        },
        {
          "regex": "https?://localhost.*",
          "mode": "internal",
          "label": "Localhost",
          "pagesToTrigger": "all"
        },
        {
          "regex": "https?://([-\\w]+\\.)*facebook\\.com.*",
          "mode": "appbrowser",
          "label": "Facebook",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([\\-\\w]+\\.)*(twitter|x)\\.com/.*",
          "mode": "appbrowser",
          "label": "Twitter/X",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*instagram\\.com/.*",
          "mode": "appbrowser",
          "label": "Instagram",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://maps\\.google\\.com.*",
          "mode": "appbrowser",
          "label": "Google Maps",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*google\\.com/maps/search/.*",
          "mode": "appbrowser",
          "label": "Google Maps Search",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://([-\\w]+\\.)*linkedin\\.com/.*",
          "mode": "appbrowser",
          "label": "LinkedIn",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?://login\\.microsoftonline\\.com.*",
          "mode": "internal",
          "label": "Microsoft Login",
          "pagesToTrigger": "custom"
        },
        {
          "regex": "https?:\\/\\/([-\\w]+\\.)*ddns.net(\\/.*)?$",
          "mode": "internal",
          "label": "All pages on my domain",
          "pagesToTrigger": "domain"
        },
        {
          "regex": ".*",
          "mode": "internal",
          "label": "All Other Links",
          "pagesToTrigger": "all"
        }
      ],
      "active": true
    },
