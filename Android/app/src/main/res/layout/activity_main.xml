<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

   <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
       android:id="@+id/swipe"
       android:layout_width="match_parent"
       android:layout_height="match_parent"
       tools:layout_behavior="@string/appbar_scrolling_view_behavior">



       <WebView
           android:id="@+id/web"
           android:layout_width="match_parent"
           android:layout_height="match_parent"/>


   </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Hidden Barcode Scanner View for silent scanning -->
    <!-- Small transparent overlay in corner for scanning -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcode_scanner"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:alpha="0.01"
        android:background="#00000000"
        app:zxing_framing_rect_width="180dp"
        app:zxing_framing_rect_height="180dp"
        app:zxing_preview_scaling_strategy="fitCenter" />


    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_centerHorizontal="true"
        android:indeterminateTint="#808080"
        android:indeterminateTintMode="src_in"
        style="?android:attr/progressBarStyle"
        />

</RelativeLayout>